    "dashboardDesc": "\u062f \u0648\u0636\u0639\u06cc\u062a \u0634\u0627\u062e\u0635\u0648\u0646\u0648\u060c \u062f \u0630\u062e\u06cc\u0631\u06d2 \u06a9\u0627\u0631\u0648\u0646\u06d0 \u0686\u0627\u0631\u062a\u0648\u0646\u0648\u060c \u0627\u0648 \u062f 3-2-1 \u067e\u0634\u062a\u0627\u0693\u06d2 \u0642\u0627\u0639\u062f\u06d0 \u06a9\u062a\u0646\u0647 \u0633\u0631\u0647 \u062f \u067c\u0648\u0644\u0648 \u067e\u0634\u062a\u0627\u0693\u0648 \u0628\u0634\u067e\u0693 \u06a9\u062a\u0646\u0647 \u062a\u0631\u0644\u0627\u0633\u0647 \u06a9\u0693\u0626\u06d0.",
    "tracking": "\u062f \u067e\u0634\u062a\u0627\u0693\u06d2 \u062a\u0639\u0642\u06cc\u0628",
    "trackingDesc": "\u0647\u0631 \u067e\u0634\u062a\u0627\u0693\u0647 \u062f \u0646\u06d0\u067c\u06d0\u060c \u0627\u0646\u062f\u0627\u0632\u06d0\u060c \u062f \u0630\u062e\u06cc\u0631\u06d0 \u0681\u0627\u06cc \u0627\u0648 \u06cc\u0627\u062f\u062f\u0627\u0634\u062a\u0648\u0646\u0648 \u0633\u0631\u0647 \u062b\u0628\u062a \u06a9\u0693\u0626\u06d0. \u067e\u0647 \u0648\u062e\u062a \u06a9\u06d0 \u062a\u0627\u0631\u06cc\u062e \u0627\u0648 \u062f \u0627\u0646\u062f\u0627\u0632\u06d0 \u0628\u062f\u0644\u0648\u0646\u0647 \u062a\u0639\u0642\u06cc\u0628 \u06a9\u0693\u0626\u06d0.",
    "scan": "\u0627\u062a\u0648\u0645\u0627\u062a\u06cc\u06a9 \u0633\u06a9\u06cc\u0646",
    "scanDesc": "\u06cc\u0648\u0647 \u0641\u0648\u0644\u0689\u0631 \u0648\u067c\u0627\u06a9\u0626\u06d0 \u0627\u0648 \u062f \u0645\u0648\u062c\u0648\u062f\u0648 \u067e\u0634\u062a\u0627\u0693\u0648 \u067e\u064a\u0698\u0646\u062f\u0646\u0647 \u062e\u067e\u0644\u06a9\u0627\u0631\u0647 \u062a\u0631\u0633\u0631\u0647 \u06a9\u0693\u0626\u06d0. \u0627\u0646\u062f\u0627\u0632\u06d0 \u067e\u0647 \u0634\u0627\u0644\u06cc\u062f \u06a9\u06d0 \u062d\u0633\u0627\u0628\u06d0\u0698\u064a.",
    "media": "\u062f \u0630\u062e\u06cc\u0631\u06d2 \u0645\u06cc\u0689\u06cc\u0627",
