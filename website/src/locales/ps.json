  "privacy": {
    "title": "\u062f \u0645\u062d\u0631\u0645\u06cc\u062a \u067e\u0627\u0644\u06cc\u0633\u064a",
    "intro": "\u0645\u0648\u0646\u0698 \u062f \u0633\u062a\u0627\u0633\u0648 \u0634\u062e\u0635\u064a \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0648 \u0633\u0627\u062a\u0646\u0647 \u0696\u0648\u0631 \u062c\u062f\u064a \u0627\u062e\u0644\u0648. \u062f\u0627 \u062f \u0645\u062d\u0631\u0645\u06cc\u062a \u067e\u0627\u0644\u06cc\u0633\u064a \u062a\u0627\u0633\u0648 \u062e\u0628\u0631\u0648\u064a \u0686\u06d0 \u0645\u0648\u0646\u0698 \u0685\u0646\u06ab\u0647 \u062f \u0633\u062a\u0627\u0633\u0648 \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0648 \u0633\u0631\u0647 \u0686\u0644\u0646\u062f.",
    "responsible": "\u0645\u0633\u0624\u0644\u0647 \u0689\u0644\u0647",
    "responsibleText": "\u067e\u0647 \u062f\u06d0 \u0648\u06cc\u0628\u067e\u0627\u06bc\u0647 \u06a9\u06d0 \u062f \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0648 \u067e\u0631\u0648\u0633\u0633 \u0644\u067e\u0627\u0631\u0647 \u0645\u0633\u0624\u0644\u0647 \u0689\u0644\u0647 \u067e\u0647 \u0642\u0627\u0646\u0648\u0646\u064a \u062e\u0628\u0631\u062a\u06cc\u0627 \u06a9\u06d0 \u0630\u06a9\u0631 \u0634\u0648\u06d0.",
    "hosting": "\u06a9\u0648\u0631\u0628\u0647 \u062a\u06cc\u0627",
    "hostingText": "\u062f\u0627 \u0648\u06cc\u0628\u067e\u0627\u06bc\u0647 \u067e\u0647 \u062e\u067e\u0644\u0648 \u0633\u0631\u0648\u0631\u0648\u0646\u0648 \u06a9\u06d0 \u06a9\u0648\u0631\u0628\u0647 \u062a\u06cc\u0627 \u06a9\u06d0\u0698\u064a. \u06a9\u0644\u0647 \u0686\u06d0 \u062a\u0627\u0633\u0648 \u062f\u06d0 \u0648\u06cc\u0628\u067e\u0627\u06bc\u06d0 \u062a\u0647 \u0644\u0627\u0633\u0631\u0633\u06cc \u06a9\u0693\u0626\u06d0\u060c \u0633\u062a\u0627\u0633\u0648 \u0628\u0631\u0627\u0648\u0632\u0631 \u062e\u067e\u0644\u06a9\u0627\u0631\u0647 \u0645\u0639\u0644\u0648\u0645\u0627\u062a (IP \u067e\u062a\u0647\u060c \u0646\u06d0\u067c\u0647/\u0648\u062e\u062a\u060c \u0644\u0627\u0633\u0631\u0633\u06cc \u0634\u0648\u06d0 \u0645\u062e) \u0632\u0645\u0648\u0646\u0698 \u0633\u0631\u0648\u0631 \u062a\u0647 \u0644\u06cc\u06ab\u064a. \u062f\u0627 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u062f \u0633\u0631\u0648\u0631 \u0644\u0627\u06ab \u0641\u0627\u06cc\u0644\u0648\u0646\u0648 \u06a9\u06d0 \u0630\u062e\u06cc\u0631\u0647 \u06a9\u06d0\u0698\u064a \u0627\u0648 \u062f \u06f3\u06f0 \u0648\u0631\u0681\u0648 \u0648\u0631\u0648\u0633\u062a\u0647 \u062e\u067e\u0644\u06a9\u0627\u0631\u0647 \u067e\u0627\u06a9\u06d0\u0698\u064a.",
    "cookies": "Cookies",
    "cookiesText": "\u062f\u0627 \u0648\u06cc\u0628\u067e\u0627\u06bc\u0647 cookies \u06cc\u0627 \u062f \u062a\u0639\u0642\u06cc\u0628 \u062a\u06a9\u0646\u0627\u0644\u0648\u0698\u06cc \u0646\u0647 \u06a9\u0627\u0631\u0648\u064a. \u0647\u06cc\u0685 \u062f \u0627\u0646\u0627\u0644\u06cc\u0632 \u0648\u0633\u06cc\u0644\u06d0 \u0646\u0647 \u06a9\u0627\u0631\u0648\u0644 \u06a9\u06d0\u0698\u064a.",
    "contact": "\u062f \u0627\u0693\u06cc\u06a9\u06d0 \u0641\u0648\u0631\u0645\u0647",
    "contactText": "\u06a9\u0644\u0647 \u0686\u06d0 \u062a\u0627\u0633\u0648 \u0645\u0648\u0646\u0698 \u062a\u0647 \u062f \u0627\u0693\u06cc\u06a9\u06d0 \u0641\u0648\u0631\u0645\u06d0 \u0644\u0647 \u0644\u0627\u0631\u06d0 \u067e\u06cc\u063a\u0627\u0645 \u0648\u0644\u06cc\u06ab\u0626\u06d0\u060c \u0633\u062a\u0627\u0633\u0648 \u0645\u0639\u0644\u0648\u0645\u0627\u062a (\u0646\u0648\u0645\u060c \u0628\u0631\u06cc\u0634\u0646\u0627\u0644\u06cc\u06a9\u060c \u067e\u06cc\u063a\u0627\u0645) \u06cc\u0648\u0627\u0632\u06d0 \u0633\u062a\u0627\u0633\u0648 \u067e\u0648\u0634\u062a\u0646\u06d0 \u062a\u0647 \u062f \u0681\u0648\u0627\u0628 \u0648\u0631\u06a9\u0648\u0644\u0648 \u0644\u067e\u0627\u0631\u0647 \u06a9\u0627\u0631\u0648\u0644 \u06a9\u06d0\u0698\u064a. \u0645\u0648\u0646\u0698 \u062f\u0627 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u062f \u062f\u0631\u06d0\u06cc\u0645\u06d0 \u0689\u0644\u06d0 \u0633\u0631\u0647 \u0646\u0647 \u0634\u0631\u06cc\u06a9\u0648\u0648.",
    "downloads": "\u0689\u0627\u0648\u0646\u0644\u0648\u0689\u0648\u0646\u0647",
    "downloadsText": "\u06a9\u0644\u0647 \u0686\u06d0 \u062a\u0627\u0633\u0648 \u0632\u0645\u0648\u0646\u0698 \u0633\u0627\u0641\u067c\u0648\u06cc\u0631 \u0689\u0627\u0648\u0646\u0644\u0648\u0689 \u06a9\u0693\u0626\u06d0\u060c \u0647\u06cc\u0685 \u0634\u062e\u0635\u064a \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0646\u0647 \u0631\u0627\u067c\u0648\u0644 \u06a9\u06d0\u0698\u064a. \u062f \u0689\u0627\u0648\u0646\u0644\u0648\u0689 \u0641\u0627\u06cc\u0644\u0648\u0646\u0647 \u0628\u06d0 \u062f \u0646\u0648\u0645\u0644\u06cc\u06a9\u0646\u0648\u064a\u0633\u0647 \u0648\u0631\u06a9\u0693\u064a.",
    "rights": "\u0633\u062a\u0627\u0633\u0648 \u062d\u0642\u0648\u0642",
    "rightsText": "\u062f GDPR \u0644\u0647 \u0645\u062e\u06d0 \u062a\u0627\u0633\u0648 \u062f \u0644\u0627\u0633\u0631\u0633\u06d0\u060c \u0633\u0645\u0648\u0646\u06d0\u060c \u067e\u0627\u06a9\u0648\u0644\u0648\u060c \u062f \u067e\u0631\u0648\u0633\u0633 \u0645\u062d\u062f\u0648\u062f\u0648\u0644\u0648\u060c \u062f \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0648 \u0644\u06cc\u06ab\u062f\u0648\u0644\u0648 \u0627\u0648 \u0627\u0639\u062a\u0631\u0627\u0636 \u062d\u0642 \u0644\u0631\u0626\u06d0. \u062f \u062f\u06d0 \u062d\u0642\u0648\u0642\u0648 \u062f \u06a9\u0627\u0631\u0648\u0644\u0648 \u0644\u067e\u0627\u0631\u0647 \u0645\u0647\u0631\u0628\u0627\u0646\u064a \u0648\u06a9\u0693\u0626 \u067e\u0647 \u0642\u0627\u0646\u0648\u0646\u064a \u062e\u0628\u0631\u062a\u06cc\u0627 \u06a9\u06d0 \u0645\u0648\u0646\u0698 \u0633\u0631\u0647 \u0627\u0693\u06cc\u06a9\u0647 \u0648\u0646\u06cc\u0633\u0626\u06d0.",
    "changes": "\u0628\u062f\u0644\u0648\u0646\u0647",
    "changesText": "\u0645\u0648\u0646\u0698 \u062f \u062f\u06d0 \u0645\u062d\u0631\u0645\u06cc\u062a \u067e\u0627\u0644\u06cc\u0633\u06d0 \u062f \u062a\u0627\u0632\u0647 \u06a9\u0648\u0644\u0648 \u062d\u0642 \u0633\u0627\u062a\u0648. \u0627\u0648\u0633\u0646\u06cd \u0646\u0633\u062e\u0647 \u0647\u0645\u06cc\u0634\u0647 \u067e\u0647 \u062f\u06d0 \u0645\u062e \u06a9\u06d0 \u0634\u062a\u0648\u0646 \u062f\u0647."
  },
  "footer": {
    "legal": "\u0642\u0627\u0646\u0648\u0646\u064a",
    "imprint": "\u0642\u0627\u0646\u0648\u0646\u064a \u062e\u0628\u0631\u062a\u06cc\u0627",
    "privacy": "\u062f \u0645\u062d\u0631\u0645\u06cc\u062a \u067e\u0627\u0644\u06cc\u0633\u064a",
    "product": "\u0645\u062d\u0635\u0648\u0644",
    "madeWith": "\u062c\u0648\u0693 \u0634\u0648\u06cc"
  }
