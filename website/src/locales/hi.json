    "disputeText": "\u092f\u0942\u0930\u094b\u092a\u0940\u092f \u0906\u092f\u094b\u0917 \u0911\u0928\u0932\u093e\u0907\u0928 \u0935\u093f\u0935\u093e\u0926 \u0938\u092e\u093e\u0927\u093e\u0928 (OS) \u0915\u0947 \u0932\u093f\u090f \u090f\u0915 \u092e\u0902\u091a \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0924\u093e \u0939\u0948: https://ec.europa.eu/consumers/odr/\u0964 \u0939\u092e \u0909\u092a\u092d\u094b\u0915\u094d\u0924\u093e \u092e\u0927\u094d\u092f\u0938\u094d\u0925\u0924\u093e \u092c\u094b\u0930\u094d\u0921 \u0915\u0947 \u0938\u092e\u0915\u094d\u0937 \u0935\u093f\u0935\u093e\u0926 \u0938\u092e\u093e\u0927\u093e\u0928 \u0915\u093e\u0930\u094d\u092f\u0935\u093e\u0939\u0940 \u092e\u0947\u0902 \u092d\u093e\u0917 \u0932\u0947\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0924\u0948\u092f\u093e\u0930 \u092f\u093e \u092c\u093e\u0927\u094d\u092f \u0928\u0939\u0940\u0902 \u0939\u0948\u0902\u0964"
  },
  "privacy": {
    "title": "\u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0928\u0940\u0924\u093f",
    "intro": "\u0939\u092e \u0906\u092a\u0915\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0921\u0947\u091f\u093e \u0915\u0940 \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0915\u094b \u092c\u0939\u0941\u0924 \u0917\u0902\u092d\u0940\u0930\u0924\u093e \u0938\u0947 \u0932\u0947\u0924\u0947 \u0939\u0948\u0902\u0964 \u092f\u0939 \u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0928\u0940\u0924\u093f \u0906\u092a\u0915\u094b \u092c\u0924\u093e\u0924\u0940 \u0939\u0948 \u0915\u093f \u0939\u092e \u0906\u092a\u0915\u0947 \u0921\u0947\u091f\u093e \u0915\u094b \u0915\u0948\u0938\u0947 \u0938\u0902\u092d\u093e\u0932\u0924\u0947 \u0939\u0948\u0902\u0964",
    "responsible": "\u091c\u093f\u092e\u094d\u092e\u0947\u0926\u093e\u0930 \u092a\u0915\u094d\u0937",
    "responsibleText": "\u0907\u0938 \u0935\u0947\u092c\u0938\u093e\u0907\u091f \u092a\u0930 \u0921\u0947\u091f\u093e \u092a\u094d\u0930\u094b\u0938\u0947\u0938\u093f\u0902\u0917 \u0915\u0947 \u0932\u093f\u090f \u091c\u093f\u092e\u094d\u092e\u0947\u0926\u093e\u0930 \u092a\u0915\u094d\u0937 \u0915\u093e\u0928\u0942\u0928\u0940 \u0938\u0942\u091a\u0928\u093e \u092e\u0947\u0902 \u0928\u093f\u0930\u094d\u0926\u093f\u0937\u094d\u091f \u0939\u0948\u0964",
    "hosting": "\u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917",
    "hostingText": "\u092f\u0939 \u0935\u0947\u092c\u0938\u093e\u0907\u091f \u0939\u092e\u093e\u0930\u0947 \u0905\u092a\u0928\u0947 \u0938\u0930\u094d\u0935\u0930 \u092a\u0930 \u0939\u094b\u0938\u094d\u091f \u0915\u0940 \u0917\u0908 \u0939\u0948\u0964 \u091c\u092c \u0906\u092a \u0907\u0938 \u0935\u0947\u092c\u0938\u093e\u0907\u091f \u092a\u0930 \u091c\u093e\u0924\u0947 \u0939\u0948\u0902, \u0924\u094b \u0906\u092a\u0915\u093e \u092c\u094d\u0930\u093e\u0909\u091c\u093c\u0930 \u0938\u094d\u0935\u091a\u093e\u0932\u093f\u0924 \u0930\u0942\u092a \u0938\u0947 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 (IP \u092a\u0924\u093e, \u0924\u093e\u0930\u0940\u0916/\u0938\u092e\u092f, \u090f\u0915\u094d\u0938\u0947\u0938 \u0915\u093f\u092f\u093e \u0917\u092f\u093e \u092a\u0947\u091c) \u0939\u092e\u093e\u0930\u0947 \u0938\u0930\u094d\u0935\u0930 \u0915\u094b \u092d\u0947\u091c\u0924\u093e \u0939\u0948\u0964 \u092f\u0939 \u0921\u0947\u091f\u093e \u0938\u0930\u094d\u0935\u0930 \u0932\u0949\u0917 \u092b\u093e\u0907\u0932\u094b\u0902 \u092e\u0947\u0902 \u0938\u094d\u091f\u094b\u0930 \u0939\u094b\u0924\u093e \u0939\u0948 \u0914\u0930 30 \u0926\u093f\u0928\u094b\u0902 \u0915\u0947 \u092c\u093e\u0926 \u0938\u094d\u0935\u091a\u093e\u0932\u093f\u0924 \u0930\u0942\u092a \u0938\u0947 \u0939\u091f\u093e \u0926\u093f\u092f\u093e \u091c\u093e\u0924\u093e \u0939\u0948\u0964",
    "cookies": "Cookies",
    "cookiesText": "\u092f\u0939 \u0935\u0947\u092c\u0938\u093e\u0907\u091f \u0915\u0942\u0915\u0940\u091c\u093c \u092f\u093e \u0915\u093f\u0938\u0940 \u091f\u094d\u0930\u0948\u0915\u093f\u0902\u0917 \u0924\u0915\u0928\u0940\u0915 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0928\u0939\u0940\u0902 \u0915\u0930\u0924\u0940\u0964 \u0915\u094b\u0908 \u090f\u0928\u093e\u0932\u093f\u091f\u093f\u0915\u094d\u0938 \u091f\u0942\u0932 \u0909\u092a\u092f\u094b\u0917 \u0928\u0939\u0940\u0902 \u0915\u093f\u090f \u091c\u093e\u0924\u0947\u0964",
    "contact": "\u0938\u0902\u092a\u0930\u094d\u0915 \u092b\u093c\u0949\u0930\u094d\u092e",
    "contactText": "\u091c\u092c \u0906\u092a \u0938\u0902\u092a\u0930\u094d\u0915 \u092b\u093c\u0949\u0930\u094d\u092e \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0939\u092e\u0947\u0902 \u0938\u0902\u0926\u0947\u0936 \u092d\u0947\u091c\u0924\u0947 \u0939\u0948\u0902, \u0924\u094b \u0906\u092a\u0915\u093e \u0921\u0947\u091f\u093e (\u0928\u093e\u092e, \u0908\u092e\u0947\u0932, \u0938\u0902\u0926\u0947\u0936) \u0915\u0947\u0935\u0932 \u0906\u092a\u0915\u0940 \u092a\u0942\u091b\u0924\u093e\u091b \u0915\u093e \u0909\u0924\u094d\u0924\u0930 \u0926\u0947\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0909\u092a\u092f\u094b\u0917 \u0915\u093f\u092f\u093e \u091c\u093e\u090f\u0917\u093e\u0964 \u0939\u092e \u092f\u0939 \u0921\u0947\u091f\u093e \u0924\u0940\u0938\u0930\u0947 \u092a\u0915\u094d\u0937\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u0938\u093e\u091d\u093e \u0928\u0939\u0940\u0902 \u0915\u0930\u0924\u0947\u0964",
    "downloads": "\u0921\u093e\u0909\u0928\u0932\u094b\u0921",
    "downloadsText": "\u091c\u092c \u0906\u092a \u0939\u092e\u093e\u0930\u093e \u0938\u0949\u092b\u094d\u091f\u0935\u0947\u092f\u0930 \u0921\u093e\u0909\u0928\u0932\u094b\u0921 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0924\u094b \u0915\u094b\u0908 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0921\u0947\u091f\u093e \u090f\u0915\u0924\u094d\u0930 \u0928\u0939\u0940\u0902 \u0915\u093f\u092f\u093e \u091c\u093e\u0924\u093e\u0964 \u0921\u093e\u0909\u0928\u0932\u094b\u0921 \u092b\u093e\u0907\u0932\u0947\u0902 \u092c\u093f\u0928\u093e \u092a\u0902\u091c\u0940\u0915\u0930\u0923 \u0915\u0947 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0940 \u091c\u093e\u0924\u0940 \u0939\u0948\u0902\u0964",
    "rights": "\u0906\u092a\u0915\u0947 \u0905\u0927\u093f\u0915\u093e\u0930",
    "rightsText": "GDPR \u0915\u0947 \u0924\u0939\u0924, \u0906\u092a\u0915\u094b \u090f\u0915\u094d\u0938\u0947\u0938, \u0938\u0941\u0927\u093e\u0930, \u0939\u091f\u093e\u0928\u0947, \u092a\u094d\u0930\u094b\u0938\u0947\u0938\u093f\u0902\u0917 \u092a\u094d\u0930\u0924\u093f\u092c\u0902\u0927, \u0921\u0947\u091f\u093e \u092a\u094b\u0930\u094d\u091f\u0947\u092c\u093f\u0932\u093f\u091f\u0940 \u0914\u0930 \u0906\u092a\u0924\u094d\u0924\u093f \u0915\u093e \u0905\u0927\u093f\u0915\u093e\u0930 \u0939\u0948\u0964 \u0907\u0928 \u0905\u0927\u093f\u0915\u093e\u0930\u094b\u0902 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0915\u0943\u092a\u092f\u093e \u0915\u093e\u0928\u0942\u0928\u0940 \u0938\u0942\u091a\u0928\u093e \u092e\u0947\u0902 \u0926\u0940 \u0917\u0908 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947 \u0939\u092e\u0938\u0947 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902\u0964",
    "changes": "\u092a\u0930\u093f\u0935\u0930\u094d\u0924\u0928",
    "changesText": "\u0939\u092e \u0907\u0938 \u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0928\u0940\u0924\u093f \u0915\u094b \u0905\u092a\u0921\u0947\u091f \u0915\u0930\u0928\u0947 \u0915\u093e \u0905\u0927\u093f\u0915\u093e\u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0930\u0916\u0924\u0947 \u0939\u0948\u0902\u0964 \u0935\u0930\u094d\u0924\u092e\u093e\u0928 \u0938\u0902\u0938\u094d\u0915\u0930\u0923 \u0939\u092e\u0947\u0936\u093e \u0907\u0938 \u092a\u0947\u091c \u092a\u0930 \u0909\u092a\u0932\u092c\u094d\u0927 \u0939\u0948\u0964"
  },
  "footer": {
    "legal": "\u0915\u093e\u0928\u0942\u0928\u0940",
    "imprint": "\u0915\u093e\u0928\u0942\u0928\u0940 \u0938\u0942\u091a\u0928\u093e",
    "privacy": "\u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0928\u0940\u0924\u093f",
    "product": "\u0909\u0924\u094d\u092a\u093e\u0926",
    "madeWith": "\u092c\u0928\u093e\u092f\u093e \u0917\u092f\u093e"
  }
