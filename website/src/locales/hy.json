    "contactText": "\u0535\u0580\u0562 \u0571\u0565\u0584 \u0574\u0565\u0566 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576 \u0565\u0584 \u0578\u0582\u0572\u0561\u0580\u056f\u0578\u0582\u0574 \u056f\u0561\u057a\u056b \u0571\u0587\u056b \u0574\u056b\u057b\u0578\u0581\u0578\u057e, \u0571\u0565\u0580 \u057f\u057e\u0575\u0561\u056c\u0576\u0565\u0580\u0568 (\u0561\u0576\u0578\u0582\u0576, \u0567\u056c. \u0570\u0561\u057d\u0581\u0565, \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576) \u056f\u0585\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u057e\u0565\u0576 \u0574\u056b\u0561\u0575\u0576 \u0571\u0565\u0580 \u0570\u0561\u0580\u0581\u0574\u0561\u0576\u0568 \u057a\u0561\u057f\u0561\u057d\u056d\u0561\u0576\u0565\u056c\u0578\u0582 \u0570\u0561\u0574\u0561\u0580\u0589 \u0544\u0565\u0576\u0584 \u0561\u0575\u057d \u057f\u057e\u0575\u0561\u056c\u0576\u0565\u0580\u0568 \u0579\u0565\u0576\u0584 \u056f\u056b\u057d\u0578\u0582\u0574 \u0565\u0580\u0580\u0578\u0580\u0564 \u056f\u0578\u0572\u0574\u0565\u0580\u056b \u0570\u0565\u057f\u0589",
    "downloads": "\u0546\u0565\u0580\u0562\u0565\u057c\u0576\u0578\u0582\u0574\u0576\u0565\u0580",
    "downloadsText": "\u0535\u0580\u0562 \u0571\u0565\u0584 \u0576\u0565\u0580\u0562\u0565\u057c\u0576\u0578\u0582\u0574 \u0565\u0584 \u0574\u0565\u0580 \u056e\u0580\u0561\u0563\u056b\u0580\u0568, \u0561\u0576\u0571\u0576\u0561\u056f\u0561\u0576 \u057f\u057e\u0575\u0561\u056c\u0576\u0565\u0580 \u0579\u0565\u0576 \u0570\u0561\u057e\u0561\u0584\u057e\u0578\u0582\u0574\u0589 \u0546\u0565\u0580\u0562\u0565\u057c\u0576\u0574\u0561\u0576 \u0586\u0561\u0575\u056c\u0565\u0580\u0568 \u057f\u0580\u0561\u0574\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0565\u0576 \u0561\u057c\u0561\u0576\u0581 \u0563\u0580\u0561\u0576\u0581\u0574\u0561\u0576\u0589",
    "rights": "\u0541\u0565\u0580 \u056b\u0580\u0561\u057e\u0578\u0582\u0576\u0584\u0576\u0565\u0580\u0568",
    "rightsText": "GDPR-\u056b \u0570\u0561\u0574\u0561\u0571\u0561\u0575\u0576 \u0571\u0565\u0584 \u056b\u0580\u0561\u057e\u0578\u0582\u0576\u0584 \u0578\u0582\u0576\u0565\u0584 \u0574\u0578\u0582\u057f\u0584\u056b, \u0578\u0582\u0572\u0572\u0574\u0561\u0576, \u057b\u0576\u057b\u0574\u0561\u0576, \u0574\u0577\u0561\u056f\u0574\u0561\u0576 \u057d\u0561\u0570\u0574\u0561\u0576\u0561\u0583\u0561\u056f\u0574\u0561\u0576, \u057f\u057e\u0575\u0561\u056c\u0576\u0565\u0580\u056b \u057f\u0565\u0572\u0561\u0583\u0578\u056d\u0574\u0561\u0576 \u0587 \u0561\u057c\u0561\u0580\u056f\u0578\u0582\u0569\u0575\u0561\u0576\u0589 \u0531\u0575\u057d \u056b\u0580\u0561\u057e\u0578\u0582\u0576\u0584\u0576\u0565\u0580\u0576 \u056b\u0580\u0561\u056f\u0561\u0576\u0561\u0581\u0576\u0565\u056c\u0578\u0582 \u0570\u0561\u0574\u0561\u0580 \u056f\u0561\u057a\u057e\u0565\u0584 \u0574\u0565\u0566 \u053b\u0580\u0561\u057e\u0561\u056f\u0561\u0576 \u056e\u0561\u0576\u0578\u0582\u0581\u0578\u0582\u0574\u0578\u0582\u0574 \u0576\u0577\u057e\u0561\u056e \u057f\u0565\u0572\u0565\u056f\u0578\u0582\u0569\u0575\u0561\u0574\u0562\u0589",
    "changes": "\u0553\u0578\u0583\u0578\u056d\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580",
    "changesText": "\u0544\u0565\u0576\u0584 \u056b\u0580\u0561\u057e\u0578\u0582\u0576\u0584 \u0565\u0576\u0584 \u057e\u0565\u0580\u0561\u057a\u0561\u0570\u0578\u0582\u0574 \u0569\u0561\u0580\u0574\u0561\u0581\u0576\u0565\u056c \u0561\u0575\u057d \u0563\u0561\u0572\u057f\u0576\u056b\u0578\u0582\u0569\u0575\u0561\u0576 \u0584\u0561\u0572\u0561\u0584\u0561\u056f\u0561\u0576\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568\u0589 \u0538\u0576\u0569\u0561\u0581\u056b\u056f \u057f\u0561\u0580\u0562\u0565\u0580\u0561\u056f\u0568 \u0574\u056b\u0577\u057f \u0570\u0561\u057d\u0561\u0576\u0565\u056c\u056b \u0567 \u0561\u0575\u057d \u0567\u057b\u0578\u0582\u0574\u0589"
  },
