      "endpoints": [
        "https://github.com/backup-tool/b4ckup-t8l/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzMDEyNTBEQUNBOEY1NkMKUldSczlhaXNEU1VCbzBiTFBXNmJoaUdEM1k5dWZLbXpKUWVQSzNUa0Z1OEt5NVk3eFpCYndPM3cK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
