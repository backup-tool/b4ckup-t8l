{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Backup Tool",
  "version": "0.1.0",
  "identifier": "com.backup-tool.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "B4cKuP T8L",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
